# ==============================================================================
# 1.7. EXPECTATIONS : PRÉVISIONS FINANCIÈRES (Inspiré du modèle Porsche)
# ==============================================================================
print("\n--- 1.7. Expectations (Income Statement & Revenue Projections) ---")

# 1. Données historiques (Revenus en Milliards de Yens)
historical_revenue = {
    2020: 2008.0, 
    2021: 2132.0, 
    2022: 2301.0, 
    2023: 2766.0, 
    2024: 3103.0
}
df_hist = pd.DataFrame(list(historical_revenue.items()), columns=['Year', 'Revenue'])
df_hist['Type'] = 'Historique'

# Fonction pour calculer le taux de croissance annuel composé (CAGR)
def calculate_cagr(start_val, end_val, periods):
    return (end_val / start_val) ** (1 / periods) - 1

# 2. Génération des projections
def generate_projections(years_to_project=5):
    last_year = 2024
    last_revenue = historical_revenue[last_year]
    
    # Hypothèses de croissance (YoY)
    growth_rates = {
        'Pessimiste': 0.03,  # Croissance lente (crise économique)
        'Neutre': 0.08,      # Croissance stable (moyenne historique)
        'Optimiste': 0.12    # Forte expansion internationale
    }
    
    projections = []
    for scenario, rate in growth_rates.items():
        current_rev = last_revenue
        for i in range(1, years_to_project + 1):
            current_rev *= (1 + rate)
            projections.append({'Year': last_year + i, 'Revenue': current_rev, 'Type': scenario})
            
    return pd.DataFrame(projections)

df_proj = generate_projections()

# Calcul des CAGR par scénario
cagr_data = {}
for scenario in ['Pessimiste', 'Neutre', 'Optimiste']:
    scen_df = df_proj[df_proj['Type'] == scenario]
    end_val = scen_df[scen_df['Year'] == 2029]['Revenue'].values[0]
    cagr_data[scenario] = calculate_cagr(historical_revenue[2024], end_val, 5)

# 3. Affichage console des résultats (Style Porsche)
print("Prévisions des Revenus du Groupe Fast Retailing (Uniqlo)")
print("==========================================================")
print("\nRevenus Historiques (2020-2024) :")
for year, rev in historical_revenue.items():
    print(f"{year}: {rev:.1f} Milliards JPY")

print("\nRésumé de l'Analyse Financière (CAGR 2024-2029) :")
for scenario, cagr in cagr_data.items():
    print(f"Scénario {scenario} : {cagr*100:.2f}% de croissance annuelle")

# 4. Visualisation Graphique
plt.figure(figsize=(12, 7))

# Historique
plt.plot(df_hist['Year'], df_hist['Revenue'], marker='o', linewidth=3, color='black', label='Historique')

# Scénarios
colors = {'Pessimiste': '#d62728', 'Neutre': '#1f77b4', 'Optimiste': '#2ca02c'}
for scenario in ['Pessimiste', 'Neutre', 'Optimiste']:
    scen_data = df_proj[df_proj['Type'] == scenario]
    # Connecter le dernier point historique au premier point projeté
    x_vals = [2024] + list(scen_data['Year'])
    y_vals = [historical_revenue[2024]] + list(scen_data['Revenue'])
    
    plt.plot(x_vals, y_vals, marker='s', linestyle='--', linewidth=2, 
             color=colors[scenario], label=f"{scenario} (CAGR: {cagr_data[scenario]*100:.1f}%)")

plt.title("Projections des Revenus d'Uniqlo (2020-2029)", fontsize=16, fontweight='bold')
plt.xlabel("Année", fontsize=14)
plt.ylabel("Revenus (Milliards de JPY)", fontsize=14)
plt.xticks(list(df_hist['Year']) + list(df_proj['Year'].unique()))
plt.legend(fontsize=12)
plt.grid(True, linestyle=':', alpha=0.7)
plt.tight_layout()
plt.show()
